{
  "manifest_version": 2,
  "name": "Prospector → HubSpot",
  "short_name": "Prospector",
  "version": "1.0.0",
  "description": "Détecte et importe automatiquement les listes de prospects de n'importe quelle page web vers HubSpot — avec pagination, déduplication et mapping intelligent.",
  "author": "AMBS Agency",

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Prospector → HubSpot"
  },

  "background": {
    "scripts": ["src/background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": ["setup.html", "setup.js", "icons/*"],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "setup.html",
    "open_in_tab": true
  },

  "homepage_url": "https://github.com/SidyLaye/prospector-hubspot-extension",

  "browser_specific_settings": {
    "gecko": {
      "id": "prospector-hubspot@ambs-agency.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  }
}
